meta {
  name: register buyer
  type: http
  seq: 5
}

post {
  url: {{url}}/auth/register/buyer
  body: json
  auth: inherit
}

body:json {
  {
    "username": "userbuyer",
    "password": "password",
    "first_name": "User",
    "last_name": "Buyer",
    "email": "example@gmail.com",
    "dni_number": "12345678"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
